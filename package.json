{
  "name": "cheapspace",
  "version": "1.0.0",
  "description": "Alternative to GitHub Codespaces. Self-hostable.",
  "private": true,
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build:css": "tailwindcss -i ./web/assets/app.css -o ./web/static/app.css --minify",
